# Claude-UDA Star Schema — Federation-Ready GraphQL Projection
#
# Transpiled from domain_model.ttl following Netflix UDA conventions.
# All types carry @udaUri directives mapping fields to the ontology.
# Designed for Postgres 18 pg_graphql (which auto-generates this from DDL),
# but also compatible with Apollo Federation via @key directives.

directive @udaUri(uri: String!) on OBJECT | FIELD_DEFINITION | ENUM | ENUM_VALUE

