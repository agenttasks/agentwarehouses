# ════════════════════════════════════════════════════════════════════
# FactSession Mappings
# ════════════════════════════════════════════════════════════════════

<urn:nflx:uda:mapping:fact_session:pg> a mapping:Mapping ;
    rdfs:label "FactSession to Postgres" ;
    mapping:domainConcept claude:FactSession ;
    mapping:container pg:claude_analytics ;
    mapping:target "claude_analytics.fact_session" ;
    mapping:fieldMapping [
        mapping:domainProperty claude:FactSession_sessionKey ;      mapping:containerField "session_key" ] , [
        mapping:domainProperty claude:FactSession_sessionId ;       mapping:containerField "session_id" ] , [
        mapping:domainProperty claude:FactSession_status ;          mapping:containerField "status" ] , [
        mapping:domainProperty claude:FactSession_userKey ;         mapping:containerField "user_key" ] , [
        mapping:domainProperty claude:FactSession_deviceKey ;       mapping:containerField "device_key" ] , [
        mapping:domainProperty claude:FactSession_surfaceKey ;      mapping:containerField "surface_key" ] , [
        mapping:domainProperty claude:FactSession_modelKey ;        mapping:containerField "model_key" ] , [
        mapping:domainProperty claude:FactSession_startTimeKey ;    mapping:containerField "start_time_key" ] , [
        mapping:domainProperty claude:FactSession_endTimeKey ;      mapping:containerField "end_time_key" ] , [
        mapping:domainProperty claude:FactSession_durationSeconds ; mapping:containerField "duration_seconds" ] , [
        mapping:domainProperty claude:FactSession_messageCount ;    mapping:containerField "message_count" ] , [
        mapping:domainProperty claude:FactSession_toolUseCount ;    mapping:containerField "tool_use_count" ] , [
        mapping:domainProperty claude:FactSession_tokenInputCount ; mapping:containerField "token_input_count" ] , [
        mapping:domainProperty claude:FactSession_tokenOutputCount; mapping:containerField "token_output_count" ] , [
        mapping:domainProperty claude:FactSession_turnCount ;       mapping:containerField "turn_count" ] , [
        mapping:domainProperty claude:FactSession_costUsd ;         mapping:containerField "cost_usd" ] .

