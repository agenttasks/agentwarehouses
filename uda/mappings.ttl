## Claude-UDA Mappings
##
## Connects domain concepts from domain_model.ttl to three data containers:
##   1. GraphQL schema (schema.graphqls) — served via pg_graphql
##   2. Avro schema (schema.avro) — Data Mesh source
##   3. Postgres tables (star_schema_pg_graphql.sql) — pg_graphql backing store
##
## Following Netflix UDA conventions: each mapping links a subgraph of the
## domain model to a subgraph of a container representation.

@prefix claude:   <https://rdf.agentwarehouses.dev/onto/claude#> .
@prefix upper:    <https://rdf.netflix.net/onto/upper#> .
@prefix uda:      <https://rdf.netflix.net/onto/uda#> .
@prefix mapping:  <https://rdf.netflix.net/onto/mapping#> .
@prefix graphql:  <https://rdf.netflix.net/onto/graphql#> .
@prefix avro:     <https://rdf.netflix.net/onto/avro#> .
@prefix pg:       <https://rdf.agentwarehouses.dev/container/postgres#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .

# ════════════════════════════════════════════════════════════════════
# Data Container Registrations
# ════════════════════════════════════════════════════════════════════

## Postgres 18 + pg_graphql container
pg:claude_analytics a uda:DataContainer ;
    rdfs:label "Claude Analytics Star Schema" ;
    rdfs:comment "Postgres 18 database with pg_graphql extension. Tables in claude_analytics schema." ;
    uda:system "postgres" ;
    uda:systemVersion "18" ;
    uda:extension "pg_graphql" ;
    uda:schema "claude_analytics" .

## GraphQL projection container
<urn:nflx:uda:graphql:claude_analytics> a uda:DataContainer ;
    rdfs:label "Claude Analytics GraphQL API" ;
    rdfs:comment "Federation-ready GraphQL schema projected from domain model. Served by pg_graphql." ;
    uda:system "graphql" ;
    uda:schemaFile "uda/schema.graphqls" .

## Avro projection container
<urn:nflx:uda:avro:claude_analytics> a uda:DataContainer ;
    rdfs:label "Claude Analytics Avro" ;
    rdfs:comment "Data Mesh Avro schema projected from domain model." ;
    uda:system "avro" ;
    uda:schemaFile "uda/schema.avro" .

# ════════════════════════════════════════════════════════════════════
# DimUser Mappings
# ════════════════════════════════════════════════════════════════════

<urn:nflx:uda:mapping:dim_user:pg> a mapping:Mapping ;
    rdfs:label "DimUser to Postgres" ;
    mapping:domainConcept claude:DimUser ;
    mapping:container pg:claude_analytics ;
    mapping:target "claude_analytics.dim_user" ;
    mapping:fieldMapping [
        mapping:domainProperty claude:DimUser_userKey ;       mapping:containerField "user_key" ] , [
        mapping:domainProperty claude:DimUser_userId ;        mapping:containerField "user_id" ] , [
        mapping:domainProperty claude:DimUser_email ;         mapping:containerField "email" ] , [
        mapping:domainProperty claude:DimUser_planTier ;      mapping:containerField "plan_tier" ] , [
        mapping:domainProperty claude:DimUser_orgId ;         mapping:containerField "org_id" ] , [
        mapping:domainProperty claude:DimUser_orgName ;       mapping:containerField "org_name" ] , [
        mapping:domainProperty claude:DimUser_effectiveFrom ; mapping:containerField "effective_from" ] , [
        mapping:domainProperty claude:DimUser_effectiveTo ;   mapping:containerField "effective_to" ] , [
        mapping:domainProperty claude:DimUser_isCurrent ;     mapping:containerField "is_current" ] .

<urn:nflx:uda:mapping:dim_user:graphql> a mapping:Mapping ;
    rdfs:label "DimUser to GraphQL" ;
    mapping:domainConcept claude:DimUser ;
    mapping:container <urn:nflx:uda:graphql:claude_analytics> ;
    mapping:target "CLAUDE_DimUser" ;
    mapping:fieldMapping [
        mapping:domainProperty claude:DimUser_userKey ;       mapping:containerField "claude_user_key" ] , [
        mapping:domainProperty claude:DimUser_userId ;        mapping:containerField "claude_user_id" ] , [
        mapping:domainProperty claude:DimUser_email ;         mapping:containerField "claude_email" ] , [
        mapping:domainProperty claude:DimUser_planTier ;      mapping:containerField "claude_plan_tier" ] , [
        mapping:domainProperty claude:DimUser_orgId ;         mapping:containerField "claude_org_id" ] , [
        mapping:domainProperty claude:DimUser_orgName ;       mapping:containerField "claude_org_name" ] , [
        mapping:domainProperty claude:DimUser_effectiveFrom ; mapping:containerField "claude_effective_from" ] , [
        mapping:domainProperty claude:DimUser_effectiveTo ;   mapping:containerField "claude_effective_to" ] , [
        mapping:domainProperty claude:DimUser_isCurrent ;     mapping:containerField "claude_is_current" ] .

<urn:nflx:uda:mapping:dim_user:avro> a mapping:Mapping ;
    rdfs:label "DimUser to Avro" ;
    mapping:domainConcept claude:DimUser ;
    mapping:container <urn:nflx:uda:avro:claude_analytics> ;
    mapping:target "CLAUDE_DimUser" ;
    mapping:fieldMapping [
        mapping:domainProperty claude:DimUser_userKey ;       mapping:containerField "CLAUDE_user_key" ] , [
        mapping:domainProperty claude:DimUser_userId ;        mapping:containerField "CLAUDE_user_id" ] , [
        mapping:domainProperty claude:DimUser_email ;         mapping:containerField "CLAUDE_email" ] , [
        mapping:domainProperty claude:DimUser_planTier ;      mapping:containerField "CLAUDE_plan_tier" ] , [
        mapping:domainProperty claude:DimUser_orgId ;         mapping:containerField "CLAUDE_org_id" ] , [
        mapping:domainProperty claude:DimUser_orgName ;       mapping:containerField "CLAUDE_org_name" ] , [
        mapping:domainProperty claude:DimUser_effectiveFrom ; mapping:containerField "CLAUDE_effective_from" ] , [
        mapping:domainProperty claude:DimUser_effectiveTo ;   mapping:containerField "CLAUDE_effective_to" ] , [
        mapping:domainProperty claude:DimUser_isCurrent ;     mapping:containerField "CLAUDE_is_current" ] .

