{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/install_pkgs.sh",
            "timeout": 300,
            "statusMessage": "Installing project dependencies..."
          }
        ]
      }
    ]
  }
}
